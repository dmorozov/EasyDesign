{
  "name": "easydesign",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "description": "Visual UI design tool — IR + multi-target generators (React/Angular/HTML/MJML) + React Aria component layer",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tokens": "node src/theme/style-dictionary.config.mjs",
    "generate": "tsx --tsconfig ./tsconfig.app.json src/dev/generate-sample.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@xyflow/react": "^12.11.0",
    "react": "^19.2.7",
    "react-aria-components": "^1.13.0",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "mjml": "^5.3.0",
    "prettier": "3.8.4",
    "style-dictionary": "^5.4.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.1.0",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
