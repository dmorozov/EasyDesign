{
  "color": {
    "brand": { "$type": "color", "$value": "#4f46e5" },
    "onBrand": { "$type": "color", "$value": "#ffffff" },
    "surface": { "$type": "color", "$value": "#ffffff" },
    "page": { "$type": "color", "$value": "#f3f4f6" },
    "text": { "$type": "color", "$value": "#111827" },
    "muted": { "$type": "color", "$value": "#6b7280" }
  },
  "space": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "24px" }
  },
  "radius": {
    "lg": { "$type": "dimension", "$value": "12px" }
  },
  "font": {
    "family": { "$type": "fontFamily", "$value": "Helvetica, Arial, sans-serif" },
    "size": {
      "sm": { "$type": "dimension", "$value": "14px" },
      "base": { "$type": "dimension", "$value": "16px" },
      "lg": { "$type": "dimension", "$value": "18px" },
      "xl": { "$type": "dimension", "$value": "20px" },
      "2xl": { "$type": "dimension", "$value": "24px" },
      "3xl": { "$type": "dimension", "$value": "30px" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.25 },
      "normal": { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.625 }
    },
    "letterSpacing": {
      "normal": { "$type": "dimension", "$value": "0px" },
      "tight": { "$type": "dimension", "$value": "-0.5px" }
    }
  },
  "text": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.3xl}",
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "{font.lineHeight.tight}"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.2xl}",
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "{font.lineHeight.tight}"
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.xl}",
        "fontWeight": "{font.weight.semibold}",
        "lineHeight": "{font.lineHeight.tight}"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.base}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.lineHeight.normal}"
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.lineHeight.normal}"
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.medium}",
        "lineHeight": "{font.lineHeight.normal}"
      }
    }
  }
}
